{
  "layer": "top",
  "position": "top",
  "height": 40,
  "margin-top": 6,
  "margin-left": 10,
  "margin-right": 10,
  "spacing": 0,
  "reload_style_on_change": true,
  "modules-left": ["custom/arch", "hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right": [
    "backlight",
    "pulseaudio",
    "bluetooth",
    "network",
    "cpu",
    "memory",
    "battery",
    "custom/power"
  ],

  "custom/arch": {
    "format": "󰣇",
    "on-click": "ghostty -e bash -c 'fastfetch; read -p \"Press Enter to close...\"'",
    "tooltip": false
  },

  "hyprland/workspaces": {
    "format": "{name}",
    "persistent-workspaces": {}
  },

  "hyprland/window": {
    "format": "{}",
    "max-length": 40,
    "rewrite": {
      "(.*) — Zen Browser": "󰈹  $1",
      "(.*) - Mozilla Firefox": "󰈹  $1",
      "(.*) - Zed": "󰘦 $1"
    },
    "separate-outputs": false
  },

  "clock": {
    "format": "  {:%I:%M %p}",
    "format-alt": "  {:%A, %d %B %Y}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },

  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["󰃞", "󰃟", "󰃠"],
    "on-scroll-up": "brightnessctl set 1%-",
    "on-scroll-down": "brightnessctl set 1%+"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "󰂯 {volume}%",
    "format-muted": "󰝟 Muted",
    "format-icons": ["󰕿", "󰖀", "󰕾"],
    "scroll-step": 2,
    "on-click": "pavucontrol",
    "ignored-sinks": ["Easy Effects Sink"]
  },

  "bluetooth": {
    "format": "󰂯 {num_connections}",
    "format-connected": "󰂱 {num_connections}",
    "format-disabled": "󰂲 Off",
    "on-click": "blueman-manager",
    "tooltip-format": "{controller_alias}\n{num_connections} connected"
  },

  "network": {
    "interval": 5,
    "format-wifi": "󰤨  {bandwidthTotalBytes}",
    "format-ethernet": "  {bandwidthTotalBytes}",
    "format-disconnected": "󰤭  Offline",
    "tooltip-format-wifi": "IP: {ipaddr}\nNetwork: {essid}\nSignal: {signalStrength}%\nUp: {bandwidthUpBytes} Down: {bandwidthDownBytes}",
    "tooltip-format-ethernet": "IP: {ipaddr}\nUp: {bandwidthUpBytes} Down: {bandwidthDownBytes}",
    "tooltip-format-disconnected": "No connection",
    "on-click": "ghostty -e nmtui"
  },

  "cpu": {
    "format": "  {usage}%",
    "interval": 5,
    "on-click": "ghostty -e btop"
  },

  "memory": {
    "format": "  {}%",
    "interval": 5,
    "tooltip-format": "Used: {used}GB / {total}GB",
    "on-click": "ghostty -e btop"
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-plugged": "󰚥 {capacity}%",
    "format-full": "󰁹 Full",
    "format-icons": ["󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"]
  },

  "custom/power": {
    "format": "⏻",
    "on-click": "~/.config/waybar/power-menu.sh",
    "tooltip": false
  }
}
