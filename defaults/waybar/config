{
  "layer": "top",
  "position": "top",
  "height": 40,
  "margin-top": 6,
  "margin-left": 10,
  "margin-right": 10,
  "spacing": 0,
  "reload_style_on_change": true,
  "modules-left": ["custom/arch", "hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right": [
    "backlight",
    "pulseaudio",
    "bluetooth",
    "network",
    "cpu",
    "custom/gpu",
    "memory",
    "battery",
    "custom/power"
  ],

  "custom/arch": {
    "format": "σΑΘ΅",
    "on-click": "ghostty -e bash -c 'fastfetch; read -p \"Press Enter to close...\"'",
    "tooltip": false
  },

  "hyprland/workspaces": {
    "format": "{name}",
    "persistent-workspaces": {}
  },

