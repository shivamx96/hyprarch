{
  "layer": "top",
  "position": "top",
  "height": 36,
  "spacing": 0,
  "modules-left": ["custom/arch", "hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right": [
    "backlight",
    "pulseaudio",
    "bluetooth",
    "cpu",
    "memory",
    "network",
    "battery",
    "custom/power"
  ],

  "custom/arch": {
    "format": "≤░μΘ",
    "on-click": "ghostty -e bash -c 'fastfetch; read -p \"Press Enter to close...\"'",
    "tooltip": false
  },

  "hyprland/workspaces": {
    "format": "{name}",
    "persistent-workspaces": {}
  },

  "hyprland/window": {
    "format": "{}",
    "max-length": 50,
    "rewrite": {
      "(.*) - Mozilla Firefox": "ΏθΝΡ $1",
      "(.*) - Zed": "≤░αο $1"
    },
    "separate-outputs": false
  },

  "clock": {
    "format": "{:%I:%M %p}",
    "format-alt": "{:%Y-%m-%d}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },

  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["≤░Δη ", "≤░Δθ ", "≤░Δι "],
    "on-scroll-up": "brightnessctl set 1%-",
    "on-scroll-down": "brightnessctl set 1%+"
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{icon} {volume}%",
    "format-muted": "ΎΑο Muted",
    "format-icons": ["ΎΑο", "ΎΑπ ", "ΎΑρ "],
    "scroll-step": 2,
    "reverse-scrolling": true,
    "on-click": "pavucontrol",
    "ignored-sinks": ["Easy Effects Sink"]
  },

  "bluetooth": {
    "format": "≤░Γψ",
    "format-connected": "≤░Γψ {num_connections}",
    "format-disabled": "≤░Γ▓ off",
    "on-click": "blueman-manager",
    "tooltip-format": "{controller_alias}\n{num_connections} connected"
  },

  "cpu": {
    "format": "ΎΤ╝   {usage}%",
    "on-click": "ghostty -e bash -c 'btop'",
    "interval": 1
  },

  "memory": {
    "format": "Ό┐Ζ   {}%",
    "on-click": "ghostty -e bash -c 'btop'",
    "interval": 1,
    "tooltip-format": "Used: {used}GB\nTotal: {total}GB"
  },

  "network": {
    "format-wifi": "ΎΘτ   {bandwidthTotalBytes}",
    "format-ethernet": "Ό╜Ε   {bandwidthTotalBytes}",
    "format-disconnected": "ύζΛ",
    "tooltip-format-wifi": "IP: {ipaddr}\nNetwork: {essid}\nUplink: {bandwidthUpBytes}\nDownlink: {bandwidthDownBytes}",
    "tooltip-format-ethernet": "IP: {ipaddr}\nNetwork: Ethernet\nUplink: {bandwidthUpBytes}\nDownlink: {bandwidthDownBytes}"
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": " {capacity}%",
    "format-plugged": " {capacity}%",
    "format-icons": ["≤░ΓΟ", "≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"]
  },

  "custom/power": {
    "format": "έΠ╗",
    "on-click": "~/.config/waybar/power-menu.sh",
    "tooltip": false
  }
}
