{
  "layer": "top",
  "position": "top",
  "height": 40,
  "margin-top": 6,
  "margin-left": 10,
  "margin-right": 10,
  "spacing": 0,
  "reload_style_on_change": true,
  "modules-left": ["custom/arch", "hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right": [
    "custom/brightness",
    "pulseaudio",
    "bluetooth",
    "network",
    "custom/cpu",
    "custom/gpu",
    "memory",
    "battery",
    "custom/power"
  ],

  "custom/arch": {
    "format": "َ°£‡",
    "on-click": "ghostty -e bash -c 'fastfetch; read -p \"Press Enter to close...\"'",
    "tooltip": false
  },

  "hyprland/workspaces": {
    "format": "{name}",
    "persistent-workspaces": {}
  },

  "hyprland/window": {
    "format": "{}",
    "max-length": 40,
    "rewrite": {
      "(.*) â€” Zen Browser": "َ°ˆ¹  $1",
      "(.*) - Mozilla Firefox": "َ°ˆ¹  $1",
      "(.*) - Zed": "َ°ک¦ $1"
    },
    "separate-outputs": false
  },

  "clock": {
    "format": "  {:%I:%M %p}",
    "format-alt": "  {:%A, %d %B %Y}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },

  "custom/brightness": {
    "exec": "~/.local/share/hyprarch/shell/brightness-module.sh",
    "format": "{}",
    "return-type": "json",
    "interval": 5,
    "on-scroll-up": "~/.local/share/hyprarch/shell/brightness.sh up 1",
    "on-scroll-down": "~/.local/share/hyprarch/shell/brightness.sh down 1"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "َ°‚¯ {volume}%",
    "format-muted": "َ°‌ں Muted",
    "format-icons": ["َ°•؟", "َ°–€", "َ°•¾"],
    "scroll-step": 2,
    "on-click": "pavucontrol",
    "ignored-sinks": ["Easy Effects Sink"]
  },

  "bluetooth": {
    "format": "َ°‚¯ {num_connections}",
    "format-connected": "َ°‚± {num_connections}",
    "format-disabled": "َ°‚² Off",
    "on-click": "blueman-manager",
    "tooltip-format": "{controller_alias}\n{num_connections} connected"
  },

  "network": {
    "interval": 5,
    "format-wifi": "َ°¤¨  {bandwidthTotalBytes}",
    "format-ethernet": "î½„  {bandwidthTotalBytes}",
    "format-disconnected": "َ°¤­  Offline",
    "tooltip-format-wifi": "IP: {ipaddr}\nNetwork: {essid}\nSignal: {signalStrength}%\nUp: {bandwidthUpBytes} Down: {bandwidthDownBytes}",
    "tooltip-format-ethernet": "IP: {ipaddr}\nUp: {bandwidthUpBytes} Down: {bandwidthDownBytes}",
    "tooltip-format-disconnected": "No connection",
    "on-click": "ghostty -e nmtui"
  },

  "custom/cpu": {
    "exec": "~/.local/share/hyprarch/shell/cpu-usage.sh",
    "format": "ï’¼  {text}%",
    "tooltip": "{tooltip}",
    "return-type": "json",
    "interval": 5,
    "on-click": "ghostty -e btop"
  },

  "memory": {
    "format": "î؟…  {}%",
    "interval": 5,
    "tooltip-format": "Used: {used}GB / {total}GB",
    "on-click": "ghostty -e btop"
  },

  "custom/gpu": {
    "exec": "~/.local/share/hyprarch/shell/gpu-usage.sh",
    "format": "َ°¾²  {text}%",
    "tooltip": "{tooltip}",
    "return-type": "json",
    "interval": 5,
    "on-click": "ghostty -e nvtop"
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "َ°‚„ {capacity}%",
    "format-plugged": "َ°ڑ¥ {capacity}%",
    "format-full": "َ°پ¹ Full",
    "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"]
  },

  "custom/power": {
    "format": "âڈ»",
    "on-click": "~/.config/waybar/power-menu.sh",
    "tooltip": false
  }
}
